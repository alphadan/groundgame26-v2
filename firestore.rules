rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

  // --- 1. NOTIFICATION SYSTEM (Admin Only) ---

    // History & Templates: Only accessible by leadership/admins
    match /notifications_history/{id} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['area_chair', 'county_chair', 'state_admin', 'developer'];
    }

    match /notification_templates/{id} {
      allow read, write: if request.auth != null &&
        request.auth.token.role in ['area_chair', 'county_chair', 'state_admin', 'developer'];
    }

    // Topics: Everyone can read (for the composer/settings), but only Admins create/delete
    match /notification_topics/{topicId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role in ['state_admin', 'developer'];
    }

    // --- 2. USERS & FCM TOKENS ---
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.role in ['area_chair', 'county_chair', 'state_admin', 'developer']);

      // Main Profile Update Logic
      allow update: if request.auth != null && (
        request.auth.token.role in ['area_chair', 'county_chair', 'state_admin', 'developer'] ||
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'points_balance', 'active']))
      );

      // SUB-COLLECTION: FCM Tokens (Used by NotificationSetup.tsx)
      match /fcmTokens/{token} {
        // A user can manage their own device tokens
        allow read, write: if request.auth != null && request.auth.uid == userId;
        // Admins can see tokens for debugging delivery issues
        allow read: if request.auth != null && request.auth.token.role in ['state_admin', 'developer'];
      }
    }

    // 3. GLOBAL CATCH-ALL (Safety net for the other 19 collections)

    match /config/app_control {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role == "developer";
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
